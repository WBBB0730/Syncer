{
  "name": "syncer-desktop",
  "version": "2.0.0-beta.1",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=24.3.0"
  },
  "description": "Syncer desktop — LAN device collaboration",
  "main": "./out/main/index.js",
  "author": "WBBB",
  "homepage": "https://github.com/WBBB0730/Syncer",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache --max-warnings 0 .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "node scripts/test.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win --publish never",
    "build:win:debug": "pnpm run typecheck && electron-vite build --mode development && electron-builder --win --publish never"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@nut-tree-fork/libnut-win32": "^2.7.5",
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.21",
    "koffi": "^3.1.1",
    "pinia": "^3.0.4",
    "write-file-atomic": "^7.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@syncer/protocol": "workspace:*",
    "@types/node": "^24.13.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
